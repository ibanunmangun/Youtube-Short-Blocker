{
  "manifest_version": 3,
  "name": "YouTube Shorts Blocker",
  "version": "1.1",
  "description": "Removes Shorts from the YouTube interface with a toggle switch.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "css": ["hide-shorts.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
